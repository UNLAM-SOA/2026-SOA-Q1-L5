    {
        "id": "b5fac0c4d7760516",
        "type": "function",
        "z": "soaflow",
        "name": "Cache data",
        "func": "const [device, ...rest] = msg.topic.split(\"/\")\n\nlet shelf\nlet type\n\nif (rest.length === 1) {\n    type = rest[0]\n} else {\n    shelf = rest[0]\n    type = rest[1]\n}\n\nlet data = flow.get(device)\ndata ??= {}\n\nswitch (type) {\n    case \"health\":\n        data.health = msg.payload\n        break\n\n    case \"system\":\n        data.system = msg.payload\n        break\n\n    case \"alarm\":\n        data.alarm = msg.payload\n        break\n\n    case \"stock\":\n        data.shelves ??= {}\n        data.shelves[shelf] ??= {}\n        data.shelves[shelf].stock = msg.payload\n        break\n\n    case \"security\":\n        data.shelves ??= {}\n        data.shelves[shelf] ??= {}\n        data.shelves[shelf].security = msg.payload\n        break\n\n    default:\n        break\n}\n\ndata.lastUpdate = Date.now()\n\nflow.set(device, data)\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 100,

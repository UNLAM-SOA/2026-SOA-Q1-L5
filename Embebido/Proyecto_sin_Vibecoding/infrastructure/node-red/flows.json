    {
        "id": "soa-sql-select",
        "type": "sqlite",
        "z": "soaflow",
        "mydb": "soadb",
        "sqlquery": "prepared",
        "sql": "SELECT\n    offset,\n    last_update\nFROM tares\nWHERE\n    device_id = $deviceID\n    AND shelf_id = $shelfID;\n",
        "name": "Get tare data",
        "x": 950,
        "y": 1000,
        "wires": [["fn-tare-state"]]
    },
    {
        "id": "fn-tare-state",
        "type": "function",
        "z": "soaflow",
        "name": "Inject tare data into message and more",
        "func": "const { $deviceID: deviceID, $shelfID: shelfID } = msg.params\nconst { offset, last_update: lastUpdate } = msg.payload.length ? msg.payload[0] : [{}]\n\nif (!deviceID || !shelfID) return null\n\nmsg.topic = `${deviceID}/${shelfID}/tare`\n\nif (offset === undefined || lastUpdate === undefined) {\n    msg.payload = {}\n    return msg\n}\n\nlet data = flow.get(deviceID)\n\ndata ??= {}\ndata.shelves ??= {}\ndata.shelves[shelfID] ??= {}\ndata.shelves[shelfID].tare = {\n    offset,\n    lastUpdate\n}\n\nflow.set(deviceID, data)\n\nmsg.payload = {\n    offset,\n    lastUpdate\n}\n\ndelete msg.deviceID\ndelete msg.shelfID\n\nreturn msg\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1210,
        "y": 1000,
        "wires": [["out-tare-state"]]
    },

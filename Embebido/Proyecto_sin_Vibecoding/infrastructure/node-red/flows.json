    {
        "id": "fn-tare-upsert",
        "type": "function",
        "z": "soaflow",
        "name": "Inject data into the message parameters and more",
        "func": "const [device, shelf] = msg.topic.split(\"/\")\nconst { offset } = msg.payload\n\nif (!device || !shelf || offset === undefined) return null\n\nlet data = flow.get(device)\n\ndata ??= {}\ndata.shelves ??= {}\ndata.shelves[shelf] ??= {}\n\nconst lastUpdate = Date.now()\n\ndata.shelves[shelf].tare = {\n    offset: parseInt(offset),\n    lastUpdate\n}\n\nflow.set(device, data)\n\nmsg.params = {\n    $deviceID: device,\n    $shelfID: shelf,\n    $offset: data.shelves[shelf].tare.offset,\n    $lastUpdate: data.shelves[shelf].tare.lastUpdate\n}\n\nreturn msg\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 1060,
        "wires": [["soa-sql-upsert"]]
    },
    {
        "id": "soa-sql-upsert",
        "type": "sqlite",
        "z": "soaflow",
        "mydb": "soadb",
        "sqlquery": "prepared",
        "sql": "INSERT INTO tares (\n    device_id,\n    shelf_id,\n    offset,\n    last_update\n) VALUES (\n    $deviceID,\n    $shelfID,\n    $offset,\n    $lastUpdate\n) ON CONFLICT(device_id, shelf_id) DO UPDATE SET offset=$offset, last_update=$lastUpdate;\n",
        "name": "Insert tare data",
        "x": 960,
        "y": 1060,
        "wires": [[]]

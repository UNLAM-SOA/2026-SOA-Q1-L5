    {
        "id": "fn-tare-select",
        "type": "function",
        "z": "soaflow",
        "name": "Inject data into the message parameters",
        "func": "const [device, shelf] = msg.topic.split(\"/\")\n\nif (!device || !shelf) return null\n\nmsg.params = {\n    $deviceID: device,\n    $shelfID: shelf\n}\n\nreturn msg\n",

    {
        "id": "fn-stock",
        "type": "function",
        "z": "soaflow",
        "name": "Activate/Deactivate stock mode",
        "func": "const { device } = msg.req.params\nconst { status } = msg.req.body\n\nif (!device) {\n    msg.statusCode = 400\n    msg.payload = {\n        error: \"Missing parameter `device`.\"\n    }\n\n    return [msg, null]\n} else if (typeof status !== \"string\" || ![\"ON\", \"OFF\"].includes(status.toUpperCase())) {\n    msg.statusCode = 400\n    msg.payload = {\n        error: 'Missing `status` on request body or invalid value. Must be `\"ON\"` or `\"OFF\"`.'\n    }\n\n    return [msg, null]\n}\n\nmsg.statusCode = 200\nmsg.topic = `${device}/stock`\nmsg.payload = {\n    status: status.toUpperCase()\n}\n\nconst response = { ...msg }\ndelete response.topic\ndelete response.payload\n\nreturn [response, msg]\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 560,
        "wires": [["09fe019539f3c074"], ["106249346a54f770"]]

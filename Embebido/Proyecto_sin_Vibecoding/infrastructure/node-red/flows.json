    {
        "id": "fn-get-state",
        "type": "function",
        "z": "soaflow",
        "name": "Get cached data",
        "func": "const { device } = msg.req.params\n\nif (!device) {\n    msg.statusCode = 400\n    msg.payload = {\n        error: \"Missing parameter `device`.\"\n    }\n\n    return msg\n}\n\nconst data = flow.get(device)\n\nif (!data) {\n    msg.statusCode = 404\n    msg.payload = {\n        error: `Flow variable \\`${device}\\` not found.`\n    }\n\n    return msg\n}\n\nmsg.statusCode = 200\nmsg.payload = data\n\nreturn msg\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 460,
        "wires": [["http-resp"]]
    },
